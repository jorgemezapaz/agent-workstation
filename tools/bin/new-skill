#!/usr/bin/env bash
# Crea el esqueleto de una nueva skill en el repo.
# Uso: new-skill <nombre-de-la-skill>
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Uso: new-skill <nombre-de-la-skill>" >&2
  exit 1
fi

name="$1"
# Raiz del repo = dos niveles arriba de este script (tools/bin/..)
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$script_dir/../.." && pwd)"
skill_dir="$repo_dir/skills/$name"

if [ -d "$skill_dir" ]; then
  echo "Ya existe una skill llamada '$name'." >&2
  exit 1
fi

mkdir -p "$skill_dir"
cat > "$skill_dir/SKILL.md" <<EOF
---
name: $name
description: TODO describe cuando debe usarse esta skill (que la dispara).
---

# ${name}

TODO: contenido de la skill.

## Cuando usar esta skill

TODO.

## Pasos

1. TODO
EOF

echo "Creada: skills/$name/SKILL.md"
echo "Recuerda ejecutar el instalador (o ya esta enlazado si usas symlinks)."
